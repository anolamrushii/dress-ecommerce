# ---------------------------------------------------------------------------
# apps/api (FastAPI)
# ---------------------------------------------------------------------------

# PostgreSQL connection string. Locally via docker-compose:
#   postgresql://egzona:egzona@localhost:5432/egzona_abazi
# On Neon, copy the pooled connection string from the Neon dashboard.
DATABASE_URL=postgresql://egzona:egzona@localhost:5432/egzona_abazi

# Secret used to sign admin JWTs. Generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string


# Cloudinary connection string, from the Cloudinary dashboard:
# Account Details -> API Environment variable
CLOUDINARY_URL=cloudinary://<api_key>:<api_secret>@<cloud_name>

# Comma-separated list of origins allowed to call the API (the Next.js app).
CORS_ORIGIN=http://localhost:3000

# ---------------------------------------------------------------------------
# apps/web (Next.js)
# ---------------------------------------------------------------------------

# Base URL of the FastAPI backend, reachable from the browser.
NEXT_PUBLIC_API_URL=http://localhost:8000
